# Telegram — get token from @BotFather (/newbot), your user ID from @userinfobot
TELEGRAM_TOKEN=7123456789:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_ALLOWED_USER_ID=123456789

# Webhook — your public HTTPS URL (no trailing slash)
# Local dev: use ngrok (see README)
# Production: your domain or cloud provider URL
WEBHOOK_BASE_URL=https://your-domain.example.com:8443
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
WEBHOOK_SECRET_TOKEN=generate_a_64_char_hex_string_here

# Anthropic Claude — console.anthropic.com
# Used as primary for URL/PDF fetching; fallback for Gemini failures
ANTHROPIC_API_KEY=sk-ant-api03-xxxx
CLAUDE_MODEL=claude-sonnet-4-6

# Google Gemini — aistudio.google.com (free tier available)
# Primary model for general queries — has built-in Google Search
GEMINI_API_KEY=AIzaSy-xxxx
GEMINI_MODELS=gemini-2.5-flash-lite,gemini-2.5-flash

# xAI Grok — console.x.ai (used for /wiki command)
XAI_API_KEY=xai-xxxx

# Behavior
MAX_RESPONSE_CHARS=280
MAX_TOOL_ITERATIONS=5
